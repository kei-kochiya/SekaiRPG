; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="PJSK_RPG"
run/main_scene="res://Scenes/StartMenu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="uid://bubsa2phqp7kb"

[autoload]

GameManager="*res://Scripts/GameManager.gd"
DialogueManager="*res://UI/DialogueManager.gd"
DialogueLoader="*res://Scripts/DialogueLoader.gd"
ScreenFade="*res://UI/ScreenFade.gd"
UpgradeUI="*res://UI/UpgradeUI.tscn"
PauseMenu="*res://UI/PauseMenu.gd"
MobileControls="*res://UI/MobileControls.gd"

[display]

window/size/viewport_width=1152
window/size/viewport_height=648
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/stretch/scale_mode="integer"

[input_devices]

pointing/emulate_touch_from_mouse=true
pointing/emulate_mouse_from_touch=true

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
textures/vram_compression/import_etc2_astc=true
